{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pi-rn.local/schemas/note.schema.json",
  "title": "pi-chart note frontmatter",
  "description": "YAML frontmatter for narrative notes under timeline/*/notes/*.md. The note ID must have a corresponding communication event in events.ndjson that references it via data.note_ref (validator enforces both directions). 'references' is required (may be empty) so the validator can audit referential integrity.",
  "type": "object",
  "required": [
    "id",
    "type",
    "subject",
    "encounter_id",
    "effective_at",
    "recorded_at",
    "author",
    "source",
    "status",
    "references"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^note_[0-9]{8}T[0-9]{4,6}(_[A-Za-z0-9_-]+)?$"
    },
    "type": {
      "const": "communication"
    },
    "subtype": {
      "type": "string",
      "description": "e.g. sbar, progress_note, handoff, portal_message, phone_note"
    },
    "subject":      { "type": "string" },
    "encounter_id": { "type": "string" },
    "effective_at": { "type": "string", "format": "date-time" },
    "recorded_at":  { "type": "string", "format": "date-time" },
    "author": {
      "type": "object",
      "required": ["id", "role"],
      "properties": {
        "id":     { "type": "string" },
        "role":   { "type": "string" },
        "run_id": { "type": "string" }
      }
    },
    "source": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string" },
        "ref":  { "type": "string" }
      }
    },
    "references": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of events or other notes this note refers to. May be empty. Validator confirms each id resolves."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "final", "superseded", "entered_in_error"]
    }
  }
}
