#!/usr/bin/env bash
set -euo pipefail

remote_name="${1:-}"
remote_url="${2:-}"

if [[ "${ALLOW_PUBLIC_PUSH:-}" == "1" ]]; then
  exit 0
fi

case "${remote_name} ${remote_url}" in
  *" github.com:"*|*" github.com/"*|origin\ git@github.com:*|origin\ https://github.com/*)
    cat >&2 <<'MSG'
Blocked push to public GitHub remote.

This repository keeps local agent/prototype work in Git for durability, but
public pushes should be explicit and reviewed first.

To push after reviewing the outgoing commits, run:
  ALLOW_PUBLIC_PUSH=1 git push <remote> <refspec>

Useful review commands:
  git status --short
  git log --oneline --decorate --stat @{u}..HEAD
  git diff --stat @{u}..HEAD
MSG
    exit 1
    ;;
esac
