{
  "name": "pi-chart",
  "version": "0.1.0",
  "private": true,
  "description": "Filesystem-native, append-oriented, provenance-rich clinical memory substrate for the pi-agent system.",
  "type": "module",
  "scripts": {
    "migrate": "tsx scripts/migrate-v01-to-v02.ts .",
    "validate": "tsx scripts/validate.ts .",
    "rebuild": "tsx scripts/rebuild-derived.ts .",
    "check": "npm run rebuild && npm run validate",
    "dashboard": "tsx scripts/dashboard.ts",
    "dashboard:dev": "tsx scripts/dashboard-dev.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx 'src/**/*.test.ts' 'scripts/**/*.test.ts'"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  }
}
