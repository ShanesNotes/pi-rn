# Node
node_modules/
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# pi-chart specific
# _derived/ is disposable: regenerate locally via `npm run rebuild`. Tracking
# only the README to document the directory's purpose.
_derived/*.md
!_derived/README.md
patients/*/_derived/*.md
!patients/*/_derived/README.md

# Transient session state (DESIGN §2.4). sessions/current.example.yaml is
# committed as a template; sessions/current.yaml is per-workspace.
sessions/current.yaml

# Claude synthesis workshop (Karpathy-pattern LLM wiki). Rebuildable from raw
# sources + skill schema; never authoritative.
/wiki/

# Planning memos. Authoritative source inputs cited from tracked PRDs and
# ADRs; HITL governance records and research syntheses live here.
# (Previously /memos/ was ignored — that was the workspace placement error.)
!/memos/
!/memos/**

# Override parent /home/ark/pi-rn/.gitignore which ignores .omx/ globally.
# Track durable planning artifacts only; orchestration scratch (logs, state,
# tmp, runtime wiki) stays ignored.
!.omx/
!.omx/plans/
!.omx/plans/**
!.omx/specs/
!.omx/specs/**
!.omx/context/
!.omx/context/**
!.omx/drafts/
!.omx/drafts/**
!.omx/interviews/
!.omx/interviews/**
!.omx/reports/
!.omx/reports/**
!.omx/questions/
!.omx/questions/**
.omx/logs/
.omx/state/
.omx/tmp/
.omx/wiki/
# Top-level orchestration scratch (runtime config, metrics, scratchpads).
.omx/*.json
.omx/*.gitignore
.omx/notepad.md

# Generated kanban dashboard (build artifact; regen via `npm run dashboard`).
docs/plans/dashboard.html

# A9B draft staging area (superceded PRDs; not for tracking).
docs/plans/.draft/
